                subtitle: Text(actividad["descripcion"]),
              ),
            );
          }).toList(),
        ),
      ),
    );
  }
}

class NormaAmbiente extends StatelessWidget {
  final List<Map<String, dynamic>> normas = [
    {
      "icono": Icons.access_time,
      "titulo": "Llegar puntualmente",
      "descripcion": "Respeta los horarios establecidos para las actividades.",
    },
    {
      "icono": Icons.people,
      "titulo": "Respetar la palabra de los compañeros",
      "descripcion": "Escucha atentamente sin interrupciones.",
    },
    {
      "icono": Icons.devices,
      "titulo": "Cuidar los equipos",
      "descripcion": "Utiliza responsablemente los equipos y herramientas.",
    },
    {
      "icono": Icons.cleaning_services,
      "titulo": "Mantener limpio el ambiente",
      "descripcion": "Deja el espacio ordenado después de cada actividad.",
    },
    {
      "icono": Icons.thumb_up,
      "titulo": "Participar en clase",
      "descripcion": "Contribuye activamente en las discusiones y actividades.",
    },
    {
      "icono": Icons.assignment_turned_in,
