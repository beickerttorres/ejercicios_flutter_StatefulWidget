import 'package:flutter/material.dart';

void main() {
  runApp(const MiApp());
}

class MiApp extends StatelessWidget {
  const MiApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      home: (),
    );
  }
}

class InicioEducativo extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text("No Aprendes Fácil"),
        backgroundColor: const Color.fromARGB(255, 248, 19, 19),
      ),
      body: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          const Icon(
            Icons.school,
            size: 100,
            color: Color.fromARGB(255, 0, 135, 47),
          ),

          const SizedBox(height: 20),

          const Text(
            "No eres Bienvenido",
            style: TextStyle(fontSize: 28, fontWeight: FontWeight.bold),
          ),

          const Padding(
            padding: EdgeInsets.all(16),
            child: Text(
              "Aprende programación lo demas es lujo.",
              textAlign: TextAlign.center,
            ),
          ),

          Row(
            mainAxisAlignment: MainAxisAlignment.spaceEvenly,
            children: [
              tarjeta(
                Icons.code,
                "Programación que mas quieres",
                const Color.fromARGB(255, 218, 144, 33),
              ),
              tarjeta(
                Icons.calculate,
                "Matemáticas",
                const Color.fromARGB(255, 123, 150, 124),
              ),
              tarjeta(
                Icons.brush,
                "Diseño",
                const Color.fromARGB(255, 31, 121, 210),
              ),
            ],
          ),
        ],
      ),
    );
  }

  Widget tarjeta(IconData icono, String titulo, Color color) {
    return Card(
      color: color,
      child: Container(
        width: 100,
        height: 120,
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(icono, size: 40, color: Colors.white),
            SizedBox(height: 10),
            Text(titulo, style: TextStyle(color: Colors.white)),
          ],
        ),
      ),
    );
  }
}

class Agenda2 extends StatelessWidget {
  final List<Map<String, dynamic>> actividades = [
    {
      "hora": "7:00 a.m.",
      "titulo": "Llegada al ambiente",
      "descripcion": "Ingreso al salón",
      "icono": Icons.login,
    },
    {
      "hora": "8:00 a.m.",
      "titulo": "Explicación del tema",
      "descripcion": "Clase principal",
      "icono": Icons.menu_book,
    },
    {
      "hora": "10:00 a.m.",
      "titulo": "Trabajo práctico",
      "descripcion": "Actividad en grupo",
      "icono": Icons.computer,
    },
    {
      "hora": "12:00 p.m.",
      "titulo": "Almuerzo",
      "descripcion": "Tiempo de descanso",
      "icono": Icons.restaurant,
    },
    {
      "hora": "2:00 p.m.",
      "titulo": "Socialización",
      "descripcion": "Presentación de ideas",
      "icono": Icons.people,
    },
    {
      "hora": "4:00 p.m.",
      "titulo": "Entrega de evidencia",
      "descripcion": "Subir actividad",
      "icono": Icons.upload_file,
    },
    {
      "hora": "5:00 p.m.",
      "titulo": "Salida",
      "descripcion": "Fin de jornada",
      "icono": Icons.exit_to_app,
    },
  ];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text("Agenda del Día")),
      body: SingleChildScrollView(
        child: Column(
          children: actividades.map((actividad) {
            return Card(
              margin: EdgeInsets.all(10),
              child: ListTile(
                leading: Icon(actividad["icono"]),
